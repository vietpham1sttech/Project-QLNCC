@using Project_QLNCC.Suppliers.Dto
@model SupplierDto

@{
    Layout = null;
}

<div class="modal-header">
    <h5 class="modal-title">Update Supplier</h5>
    <button type="button" class="close" data-dismiss="modal">&times;</button>
</div>

<form name="supplierEditForm" role="form" class="form-horizontal">

    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="modal-body">

        <div class="form-group row required">
            <label class="col-md-3 col-form-label">Id supplier</label>
            <div class="col-md-9">
                <input type="text" name="Code" id="edit-field-Code"
                       value="@Model.Code" class="form-control"
                       placeholder="Enter Id Supplier (VD: NCC001)" />
                <span id="edit-error-Code" class="text-danger" style="display:none; font-size:13px;">
                </span>
            </div>
        </div>

        <div class="form-group row required">
            <label class="col-md-3 col-form-label">Name supplier</label>
            <div class="col-md-9">
                <input type="text" name="Name" id="edit-field-Name"
                       value="@Model.Name" class="form-control"
                       placeholder="Enter Name Supplier" />
                <span id="edit-error-Name" class="text-danger" style="display:none; font-size:13px;">
                </span>
            </div>
        </div>

        <div class="form-group row required">
            <label class="col-md-3 col-form-label">Email</label>
            <div class="col-md-9">
                <input type="email" name="Email" id="edit-field-Email"
                       value="@Model.Email" class="form-control"
                       placeholder="Enter email (VD: example@gmail.com)" />
                <span id="edit-error-Email" class="text-danger" style="display:none; font-size:13px;"></span>
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Phone numbers</label>
            <div class="col-md-9">
                <input type="text" name="Phone" value="@Model.Phone" class="form-control"
                       placeholder="Enter phone number" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Tax code</label>
            <div class="col-md-9">
                <input type="text" name="TaxCode" value="@Model.TaxCode" class="form-control"
                       placeholder="Enter tax identification number" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Address</label>
            <div class="col-md-9">
                <input type="text" name="Address" value="@Model.Address" class="form-control"
                       placeholder="Enter address" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Contact person</label>
            <div class="col-md-9">
                <input type="text" name="ContactPerson" value="@Model.ContactPerson" class="form-control"
                       placeholder="Enter contact person name" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Is active</label>
            <div class="col-md-9 d-flex align-items-center">
                <input type="checkbox" id="IsActiveCheck" @(Model.IsActive ? "checked" : "") />
                <span class="ml-1">Active</span>
            </div>
        </div>

    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary save-button">Update</button>
    </div>

</form>