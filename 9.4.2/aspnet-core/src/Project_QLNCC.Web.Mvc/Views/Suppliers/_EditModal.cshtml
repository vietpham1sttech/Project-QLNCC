@using Project_QLNCC.Suppliers.Dto
@model SupplierDto

@{
    Layout = null;
}

<div class="modal-header">
    <h5 class="modal-title">Cập nhật Supplier</h5>
    <button type="button" class="close" data-dismiss="modal">&times;</button>
</div>

<form name="supplierEditForm" role="form" class="form-horizontal">

    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="modal-body">

        <div class="form-group row required">
            <label class="col-md-3 col-form-label">Mã NCC</label>
            <div class="col-md-9">
                <input type="text" name="Code" id="edit-field-Code"
                       value="@Model.Code" class="form-control"
                       placeholder="Nhập mã Supplier (VD: NCC001)" />
                <span id="edit-error-Code" class="text-danger" style="display:none; font-size:13px;">
                    Trường này là bắt buộc.
                </span>
            </div>
        </div>

        <div class="form-group row required">
            <label class="col-md-3 col-form-label">Tên NCC</label>
            <div class="col-md-9">
                <input type="text" name="Name" id="edit-field-Name"
                       value="@Model.Name" class="form-control"
                       placeholder="Nhập tên Supplier" />
                <span id="edit-error-Name" class="text-danger" style="display:none; font-size:13px;">
                    Trường này là bắt buộc.
                </span>
            </div>
        </div>

        <div class="form-group row required">
            <label class="col-md-3 col-form-label">Email</label>
            <div class="col-md-9">
                <input type="email" name="Email" id="edit-field-Email"
                       value="@Model.Email" class="form-control"
                       placeholder="Nhập email (VD: example@gmail.com)" />
                <span id="edit-error-Email" class="text-danger" style="display:none; font-size:13px;">
                    Trường này là bắt buộc.
                </span>
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">SĐT</label>
            <div class="col-md-9">
                <input type="text" name="Phone" value="@Model.Phone" class="form-control"
                       placeholder="Nhập số điện thoại" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Mã số thuế</label>
            <div class="col-md-9">
                <input type="text" name="TaxCode" value="@Model.TaxCode" class="form-control"
                       placeholder="Nhập mã số thuế" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Địa chỉ</label>
            <div class="col-md-9">
                <input type="text" name="Address" value="@Model.Address" class="form-control"
                       placeholder="Nhập địa chỉ" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Người liên hệ</label>
            <div class="col-md-9">
                <input type="text" name="ContactPerson" value="@Model.ContactPerson" class="form-control"
                       placeholder="Nhập tên người liên hệ" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-3 col-form-label">Trạng thái</label>
            <div class="col-md-9 d-flex align-items-center">
                <input type="checkbox" id="IsActiveCheck" @(Model.IsActive ? "checked" : "") />
                <span class="ml-1">Hoạt động</span>
            </div>
        </div>

    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>
        <button type="button" class="btn btn-primary save-button">Cập nhật</button>
    </div>

</form>