@{
    ViewData["Title"] = "Quản lý Nhà cung cấp";
}
<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1><i class="fas fa-truck border-right pr-3 mr-3"></i>Quản lý Nhà cung cấp</h1>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <!-- Bộ lọc tìm kiếm -->
        <div class="card card-secondary">
            <div class="card-body">
                <div class="input-group">
                    <input type="text" id="keyword" class="form-control" placeholder="Tìm theo Mã, Tên, Email, MST hoặc SĐT...">
                    <div class="input-group-append">
                        <button type="button" class="btn btn-primary" onclick="loadData()">
                            <i class="fas fa-search"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Form Nhập liệu -->
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h3 class="card-title" id="formTitle">Thêm nhà cung cấp mới</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse"><i class="fas fa-minus"></i></button>
                </div>
            </div>
            <div class="card-body">
                <input id="id" type="hidden" />
                <div class="row">
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Mã NCC <span class="text-danger">*</span></label>
                            <input id="code" class="form-control" placeholder="VD: NCC001" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Tên nhà cung cấp <span class="text-danger">*</span></label>
                            <input id="name" class="form-control" placeholder="VD: Công ty TNHH Giải pháp STTech" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Mã số thuế</label>
                            <input id="taxCode" type="text" class="form-control" placeholder="Mã số thuế doanh nghiệp" oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Người liên hệ</label>
                            <input id="contactPerson" class="form-control" placeholder="Tên nhân viên phụ trách" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Số điện thoại</label>
                            <input id="phone" type="text" class="form-control" placeholder="Số điện thoại" oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label>Email <span class="text-danger">*</span></label>
                            <input id="email" type="email" class="form-control" placeholder="Địa chỉ Email" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Địa chỉ</label>
                            <input id="address" class="form-control" placeholder="Địa chỉ trụ sở" />
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-group">
                            <label>Trạng thái</label>
                            <select id="isActive" class="form-control">
                                <option value="true">Đang hoạt động</option>
                                <option value="false">Ngừng hợp tác</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="text-right border-top pt-3">
                    <button id="btnAdd" class="btn btn-primary px-4" onclick="create()">
                        <i class="fas fa-plus-circle mr-1"></i> Thêm mới
                    </button>

                    <button id="btnUpdate" class="btn btn-info px-4" onclick="update()" disabled>
                        <i class="fas fa-save mr-1"></i> Cập nhật 
                    </button>

                    <button class="btn btn-default" onclick="resetForm()"><i class="fas fa-sync-alt"></i> Làm mới</button>
                </div>
            </div>
        </div>

        <!-- Bảng dữ liệu -->
        <div class="card">
            <div class="card-body table-responsive p-0">
                <table class="table table-hover table-bordered text-nowrap">
                    <thead class="bg-light text-center">
                        <tr>
                            <th style="width: 100px">Mã NCC</th>    
                            <th>Tên nhà cung cấp</th>              
                            <th>MST</th>                          
                            <th>Người liên hệ</th>                
                            <th>Email & SĐT</th>                  
                            <th style="width: 100px">Trạng thái</th> 
                            <th style="width: 120px">Thao tác</th>   
                        </tr>
                    </thead>
                    <tbody id="data">
                        <!-- Dữ liệu được load từ JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/view-resources/Views/Suppliers/Index.js"></script>
}