@{
    ViewBag.Title = "Supplier";
}

@section scripts {
    <script src="~/view-resources/Views/Suppliers/Index.js"></script>
    <script src="~/view-resources/Views/Suppliers/_CreateModal.js"></script>
    <script src="~/view-resources/Views/Suppliers/_EditModal.js"></script>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-6">
                <h1>Supplier</h1>
            </div>
            <div class="col-sm-6">
                <button id="CreateNewSupplierButton"
                        class="btn btn-primary float-sm-right">
                    <i class="fa fa-plus"></i> Thêm mới
                </button>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="container-fluid">
        <div class="card">

            <!-- SEARCH -->
            <!-- SEARCH -->
            <div class="card-header">
                <div class="row g-2 align-items-center">

                    <div class="col-md-5">
                        <div class="input-group">
                            <input type="text" id="keyword" class="form-control"
                                   placeholder="Tìm kiếm theo mã, tên, email, SĐT..." />
                            <div class="input-group-append">
                                <button class="btn btn-primary" id="GetSuppliersButton">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <select id="filterIsActive" class="form-control">
                            <option value="">-- Tất cả trạng thái --</option>
                            <option value="true">Hoạt động</option>
                            <option value="false">Ngưng</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <button class="btn btn-secondary btn-block" id="ResetFilterButton">
                            <i class="fas fa-undo"></i> Reset
                        </button>
                    </div>

                </div>
            </div>

            <!-- TABLE -->
            <div class="card-body">
                <table id="SuppliersTable"
                       class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Mã</th>
                            <th>Tên</th>
                            <th>Email</th>
                            <th>SĐT</th>
                            <th>Trạng thái</th>
                            <th style="width:150px">Thao tác</th>
                        </tr>
                    </thead>
                </table>
            </div>

        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/Suppliers/_CreateModal.cshtml")

<div id="SupplierEditModal" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content"></div>
    </div>
</div>