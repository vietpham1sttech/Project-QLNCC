@{
    Layout = null;
}

<div class="modal fade" id="SupplierCreateModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Create Supplier</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>

            <form name="supplierCreateForm" class="form-horizontal">

                <div class="modal-body">

                    <div class="form-group row required">
                        <label class="col-md-3 col-form-label">Id supplier</label>
                        <div class="col-md-9">
                            <input type="text" name="Code" id="create-field-Code"
                                   class="form-control" placeholder="Enter Id Supplier (VD: NCC001)" />
                            <span id="create-error-Code" class="text-danger" style="display:none; font-size:13px;">
                            </span>
                        </div>
                    </div>

                    <div class="form-group row required">
                        <label class="col-md-3 col-form-label">Name supplier</label>
                        <div class="col-md-9">
                            <input type="text" name="Name" id="create-field-Name"
                                   class="form-control" placeholder="Enter Name Supplier" />
                            <span id="create-error-Name" class="text-danger" style="display:none; font-size:13px;">
                            </span>
                        </div>
                    </div>

                    <div class="form-group row required">
                        <label class="col-md-3 col-form-label">Email</label>
                        <div class="col-md-9">
                            <input type="email" name="Email" id="create-field-Email"
                                   class="form-control" placeholder="Enter email (VD: example@gmail.com)" />
                            <span id="create-error-Email" class="text-danger" style="display:none; font-size:13px;">
                            </span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">Phone numbers</label>
                        <div class="col-md-9">
                            <input type="text" name="Phone" class="form-control" placeholder="Enter phone number" />
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">Tax Code</label>
                        <div class="col-md-9">
                            <input type="text" name="TaxCode" class="form-control" placeholder="Enter tax code" />
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">Address</label>
                        <div class="col-md-9">
                            <input type="text" name="Address" class="form-control" placeholder="Enter Address" />
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label">Is active</label>
                        <div class="col-md-9">
                            <input type="checkbox" name="IsActive" value="true" checked />
                            <span class="ml-1">Active</span>
                        </div>
                    </div>

                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary save-button">Save</button>
                </div>

            </form>
        </div>
    </div>
</div>